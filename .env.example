# Environment Variables Example for mysawit-harvest Service
# Copy this to .env and fill in actual values for development

# === Development Environment ===
SPRING_PROFILES_ACTIVE=dev

# Database Configuration (Development)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/mysawit_harvest_db
SPRING_DATASOURCE_USERNAME=mysawit_harvest_user
SPRING_DATASOURCE_PASSWORD=mysawit_harvest_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# === Production Environment (Uncomment and Configure) ===
# SPRING_PROFILES_ACTIVE=prod
# DB_URL=jdbc:postgresql://prod-db-host.example.com:5432/mysawit_harvest_db
# DB_USERNAME=mysawit_harvest_prod
# DB_PASSWORD=your_secure_password_here
# STORAGE_DIR=/opt/harvest/uploads

# === Docker Compose Override ===
# These variables override docker-compose.yml settings if needed
# DB_URL=jdbc:postgresql://mysawit-harvest-db:5432/mysawit_harvest_db
# DB_USERNAME=mysawit_harvest_user
# DB_PASSWORD=mysawit_harvest_password

# === Application Configuration ===
# Logging level: DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ID_AC_UI_CS_ADVPROG=DEBUG
